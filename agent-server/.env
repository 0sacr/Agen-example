# ============================================================
# 电影史AI光影助手 — 环境变量配置
# ============================================================

# DeepSeek API Key（从 https://platform.deepseek.com/api_keys 获取）
# 新用户注册即送 100万 token 免费额度
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# 服务器端口（一般不需要改）
PORT=3001

# DeepSeek API 地址（不要改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型名称（deepseek-chat = DeepSeek V4）
LLM_MODEL=deepseek-chat

# 温度参数 0-1（0=精确严谨, 1=创意发散）
LLM_TEMPERATURE=0.7

# 最大对话记忆轮数（记住最近 N 轮对话上下文）
MEMORY_K=5
