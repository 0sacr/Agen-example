# ============================================================
# 电影史AI光影助手 — 环境变量模板
# 复制此文件为 .env 并填写真实 API Key
# cp .env.example .env
# ============================================================

# DeepSeek API Key（从 https://platform.deepseek.com/api_keys 获取）
# DeepSeek V4 兼容 OpenAI 接口格式，成本约 1元/百万token
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 服务器端口
PORT=3001

# DeepSeek API 基础URL（默认V4端点，无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Agent 配置
# 模型名称：deepseek-chat 对应 DeepSeek V4
LLM_MODEL=deepseek-chat
# 温度参数（0-1，越低越精确，越高越有创造性）
LLM_TEMPERATURE=0.7
# 最大对话记忆轮数（保留最近 N 轮对话上下文）
MEMORY_K=5
